modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'if [ ! -f ~/gbdk/bin/lcc ]; then echo \"Installing GBDK-2020...\"; curl -sL https://github.com/gbdk-2020/gbdk-2020/releases/download/4.5.0/gbdk-linux64.tar.gz -o /tmp/gbdk.tar.gz && tar -xzf /tmp/gbdk.tar.gz -C ~/; fi && export GBDK_HOME=~/gbdk/ && npm install && make assets && make && node server.js'"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
build = ["bash", "-c", "curl -sL https://github.com/gbdk-2020/gbdk-2020/releases/download/4.5.0/gbdk-linux64.tar.gz -o /tmp/gbdk.tar.gz && tar -xzf /tmp/gbdk.tar.gz -C ~/ && export GBDK_HOME=~/gbdk/ && npm install && make assets && make"]
